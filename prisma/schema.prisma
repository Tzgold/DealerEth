generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  CLIENT
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  IN_CHAT
  ACTIVE
  COMPLETED
  REJECTED
}

enum CampaignStatus {
  LIVE
  PAUSED
  CLOSED
}

enum DealRequestStatus {
  NEW
  ACCEPTED
  IN_DISCUSSION
  ACTIVE
  COMPLETED
  DECLINED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  password          String
  role              UserRole        @default(CREATOR)
  authProvider      String          @default("local")
  googleSub         String?         @unique
  googleDisplayName String?
  googleAvatarUrl   String?
  tiktokOpenId      String?         @unique
  tiktokUsername    String?
  tiktokDisplayName String?
  tiktokAvatarUrl   String?
  tiktokFollowers   Int?
  createdAt         DateTime        @default(now())
  profile           CreatorProfile?
  clientProfile     ClientProfile?
}

model CreatorProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  username     String        @unique
  name         String
  avatarUrl    String?
  tiktokHandle String
  bio          String
  niche        String
  followers    Int
  priceRange   String?
  sampleVideos Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealRequests DealRequest[]
  applications CampaignApplication[]
}

model DealRequest {
  id           String         @id @default(cuid())
  creatorId    String
  clientId     String?
  campaignId   String?
  name         String
  email        String
  description  String
  budget       String
  deliverables String
  status       DealRequestStatus @default(NEW)
  createdAt    DateTime       @default(now())

  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  client       ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  campaign     CampaignPost?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model ClientProfile {
  id          String         @id @default(cuid())
  userId      String         @unique
  companyName String
  avatarUrl   String?
  contactName String
  industry    String
  website     String?
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns   CampaignPost[]
  dealRequests DealRequest[]
}

model CampaignPost {
  id           String        @id @default(cuid())
  clientId     String
  title        String
  description  String
  budget       String
  niche        String
  deliverables String
  deadline     String?
  status       CampaignStatus @default(LIVE)
  createdAt    DateTime      @default(now())

  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  applications CampaignApplication[]
  dealRequests DealRequest[]
}

model CampaignApplication {
  id             String            @id @default(cuid())
  campaignId     String
  creatorId      String
  coverLetter    String
  proposedBudget String?
  status         ApplicationStatus @default(APPLIED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  campaign       CampaignPost      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator        CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  messages       ApplicationMessage[]

  @@unique([campaignId, creatorId])
}

model ApplicationMessage {
  id            String              @id @default(cuid())
  applicationId String
  senderRole    UserRole
  text          String
  createdAt     DateTime            @default(now())

  application   CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
