generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  CLIENT
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  password      String
  role          UserRole        @default(CREATOR)
  createdAt     DateTime        @default(now())
  profile       CreatorProfile?
  clientProfile ClientProfile?
}

model CreatorProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  username     String        @unique
  name         String
  tiktokHandle String
  bio          String
  niche        String
  followers    Int
  priceRange   String?
  sampleVideos Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealRequests DealRequest[]
}

model DealRequest {
  id           String         @id @default(cuid())
  creatorId    String
  name         String
  email        String
  description  String
  budget       String
  deliverables String
  createdAt    DateTime       @default(now())

  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String         @id @default(cuid())
  userId      String         @unique
  companyName String
  contactName String
  industry    String
  website     String?
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns   CampaignPost[]
}

model CampaignPost {
  id           String        @id @default(cuid())
  clientId     String
  title        String
  description  String
  budget       String
  niche        String
  deliverables String
  deadline     String?
  createdAt    DateTime      @default(now())

  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
